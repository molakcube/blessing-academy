# 1. 뼈대가 될 OS와 Node.js 버전 선택 (가벼운 alpine 버전 사용)
FROM node:18-alpine

# 2. 컨테이너 내부의 작업 폴더 지정
WORKDIR /app

# 3. 의존성 목록(package.json)을 먼저 복사하고 패키지 설치 (npm install)
COPY package.json package-lock.json* ./
RUN npm install

# 4. 나머지 내 모든 소스 코드(src 등)를 복사
COPY . .

# 5. 서버가 4060 포트를 쓸 것이라고 도커에게 알려줌
EXPOSE 4060

# 6. 컨테이너가 켜질 때 실행할 최종 명령어
CMD ["npm", "start"]